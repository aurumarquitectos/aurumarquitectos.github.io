  "faq": [
    {
      "order": 1,
      "question": "¿Necesito tener terreno para empezar?",
      "answer": "No. Podemos comenzar antes de adquirirlo y convertir tu forma de vivir en criterios útiles para evaluar ubicación, orientación y potencial.",
      "active": true
    },
    {
      "order": 2,
      "question": "¿Aurum diseña también los interiores?",
      "answer": "Sí. Arquitectura e interiores se desarrollan como una sola experiencia para evitar decisiones fragmentadas al final del proceso.",
      "active": true
    },
    {
      "order": 3,
      "question": "¿Cuál es el primer paso formal?",
      "answer": "El Perfil de Vida es una entrada breve. Si existe compatibilidad, seguimos con una Sesión de Claridad para entender contexto, alcance y horizonte.",
      "active": true
    },
    {
      "order": 4,
      "question": "¿Trabajan fuera de Hermosillo?",
      "answer": "Sí, cuando el proyecto y la forma de colaboración permiten proteger el criterio de diseño y la calidad de la ejecución.",
      "active": true
    }
  ],
